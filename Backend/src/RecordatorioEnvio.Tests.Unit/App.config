<?xml version="1.0" encoding="utf-8" ?>
<!--
  App.config para el proyecto de TESTS UNITARIOS.
  
  IMPORTANTE: Las claves de aquí son FICTICIAS para testing.
  NUNCA usar estas claves en producción.
  Las claves reales están en los Web.config de API y Web.
-->
<configuration>
  <appSettings>
    <!-- Clave AES-256 de prueba: 32 bytes en Base64 (solo para tests) -->
    <add key="EncryptionKey" value="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=" />
    <!-- Clave HMAC-SHA256 de prueba: 32 bytes en Base64 (solo para tests) -->
    <add key="HmacKey"        value="AQIDBAUGBwgJCgsMDQ4PEBESExQVFhcYGRobHB0eHyA=" />
  </appSettings>
</configuration>
