<?xml version="1.0" encoding="utf-8" ?>
<!--
  App.config para TESTS DE INTEGRACIÓN.

  IMPORTANTE: Este archivo conecta contra la base de datos Oracle REAL de desarrollo.
  - Nunca subir este archivo al control de versiones con credenciales reales
  - En CI/CD, usar variables de entorno o secrets management
  - Si cambias el entorno de conexión, actualiza solo el connectionString aquí
-->
<configuration>
  <connectionStrings>
    <!-- Cadena de conexión al Oracle de desarrollo (misma que usa la API) -->
    <add name="OracleConnection"
         connectionString="Data Source=(DESCRIPTION =(SDU=65535)(ADDRESS = (PROTOCOL = TCP)(HOST = 10.108.206.7)(PORT = 1521))(CONNECT_DATA =(SERVER = DEDICATED)(SERVICE_NAME = ORCLDV.snprivate.vcnatisae.oraclevcn.com)));User Id=GESAP;Password=GesAp.-20;Pooling=false;"
         providerName="Oracle.ManagedDataAccess.Client" />
  </connectionStrings>
  <appSettings>
    <!-- Mismas claves reales que usa la API de desarrollo -->
    <add key="EncryptionKey" value="gx9qzkSylw1eOPphKbx0At1PGKZT7XswwYp19AySPb4=" />
    <add key="HmacKey"        value="Eq80VniQq83vASNFZ4m83vARIjNEVWZ3iJmqv8zd7v8=" />
  </appSettings>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <!-- Oracle: la DLL en packages\Oracle.ManagedDataAccess.19.21.0\lib\net40 es versión 4.122.19.1 -->
      <dependentAssembly>
        <assemblyIdentity name="Oracle.ManagedDataAccess"
                          publicKeyToken="89b483f429c47342"
                          culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.122.19.1" newVersion="4.122.19.1" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
