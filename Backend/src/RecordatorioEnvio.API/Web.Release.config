<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <connectionStrings>
    <!-- SUSTITUIR 'PROD_IP' POR LA IP REAL DE PRODUCCIÓN -->
    <add name="OracleConnection" 
         connectionString="Data Source=(DESCRIPTION =(SDU=65535)(ADDRESS = (PROTOCOL = TCP)(HOST = PROD_IP)(PORT = 1521))(CONNECT_DATA =(SERVER = DEDICATED)(SERVICE_NAME = ORCLPROD)));User Id=GESAP;Password=PROD_PASSWORD;" 
         xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
  </connectionStrings>

  <appSettings>
    <!-- API KEY DE PRODUCCIÓN (Debe coincidir con la de la Web) -->
    <add key="ApiKey" value="PROD-SECURE-KEY-CHANGE-ME" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    
    <!-- Ajustes de Seguridad para Producción -->
    <add key="EsDesarrollo" value="false" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <add key="Audit_LogLevel" value="WARN" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    <!-- Aquí podrías añadir IPs reales de producción si las tuvieras -->
    <add key="Security_BlackList" value="" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
    
    <!-- CORS Producción: Sustituye el de local por el dominio real del frontal -->
    <!-- SUGERENCIA: Reemplazar el valor con la URL real del frontal en Producción si no están en el mismo dominio -->
    <add key="CorsOrigins" value="DOMINIO_FRONTAL_PRODUCCION" xdt:Transform="SetAttributes" xdt:Locator="Match(key)" />
  </appSettings>

  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
  </system.web>
</configuration>
